# Example .env file for local development.
# Copy to `.env` and fill in values: cp .env.example .env

# Docker (dev only): optional prefix for container names when several repo clones use Docker on one machine.
# Leave unset for the default names: ts-db, ts-imap-listener.
# COMPOSE_DEV_CONTAINER_PREFIX=

# App / Prisma — see src/server/database-url.server.ts (host-side dev uses port 5435 when VITE_APP_ENV=development).
# Host-side dev (bun/prisma on your machine): DATABASE_HOST=localhost. App container on deploy: db.
# Deploy credentials: .github/env/deploy.manifest.json
DATABASE_HOST=localhost
DATABASE_USER=postgres
DATABASE_PASSWORD=password
# db-pull only — see scripts/db-pull/README.md and remote-database-url.ts
DATABASE_PRODUCTION_USER=USER
DATABASE_PRODUCTION_PASSWORD=PSWD
DATABASE_STAGING_USER=USER
DATABASE_STAGING_PASSWORD=PSWD

# Scaleway object storage credentials for the backup restore test (bun run db-restore-test)
# See Bitwarden and scripts/db-pull/README.md
SCW_ACCESS_KEY=SCWXXXXXXXXXXXXXXXXXX
SCW_SECRET_KEY=00000000-0000-0000-0000-000000000000

S3_UPLOAD_ROOTFOLDER=upload-localdev

# Get from https://lightsail.aws.amazon.com/ls/webapp/eu-central-1/container-services/trassenscout-tinkering/deployments => ">" Arrow Details on "App" => Copy block of Key-Values
S3_UPLOAD_KEY=AAAAAAAAAAAAAAAAAAAA
S3_UPLOAD_SECRET=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Admin mail address, mails are sent to
ADMIN_EMAIL=trassenscout@fixmycity.de

# Key for restricted api routes
TS_API_KEY=ok
# Keys for `bun scripts/csv-import/subsubsections/index.ts config-1 staging`
TS_API_KEY_STAGING=foo
TS_API_KEY_PRODUCTION=foo

SESSION_SECRET_KEY=secretsecretsecretsecretsecretsecretsecretsecretsecretsecretsecret

# In staging/production, these come from GitHub environment variables (vars.APP_ORIGIN, inputs.ENVIRONMENT)
# Local dev: use http://127.0.0.1:4000 (Nitro app port)
VITE_APP_ORIGIN=http://127.0.0.1:4000
VITE_APP_ENV=development # development | staging | production

# for development: test the survey starting with another state
VITE_PUBLIC_SURVEY_START_STAGE=part1

# OpenAI
# info@fixmycity.de
# https://platform.openai.com/account/api-keys
OPENAI_API_KEY=AAAAAA

# Langfuse
# info@fixmycity.de
# https://cloud.langfuse.com/project/cmhaqjb4s00l0ad072yeo2rt3/settings/api-keys
LANGFUSE_SECRET_KEY=AAAAAA
LANGFUSE_PUBLIC_KEY=AAAAAA
# For EU region set base url to https://cloud.langfuse.com
LANGFUSE_BASEURL=https://cloud.langfuse.com

# Deploy-only (see .github/env/deploy.manifest.json)
APP_DOMAIN=localhost
ECR_REGISTRY=000000000000.dkr.ecr.eu-central-1.amazonaws.com
BREVO_API_KEY=
LUCKY_CLOUD_TOKEN=

# IMAP listener (docker-compose.yml / imap-listener service; dev overrides in docker-compose.override.yml)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
