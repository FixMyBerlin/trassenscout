# IMAP Listener Service - Environment Variables Example
# Kopiere diese Datei zu .env und passe die Werte an
# Statische Defaults (Ordner, Webhook-Pfad, Health-Port, …): siehe src/helpers/constants.ts

# IMAP Verbindung
IMAP_HOST=imap.migadu.com
IMAP_PORT=993
IMAP_USER=your-email@example.com
IMAP_PASSWORD=your-password

# API Konfiguration
TS_API_KEY=ok

# Lucky Cloud
# Bitwarden "luckycloud.de API"
LUCKY_CLOUD_TOKEN=123
