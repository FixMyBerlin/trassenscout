{
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "prettier.enable": false,
  "oxc.path.oxfmt": "node_modules/.bin/oxfmt",
  "oxc.path.oxlint": "node_modules/.bin/oxlint",
  "oxc.fmt.configPath": "oxfmt.config.mjs",
  "oxc.lint.configPath": "oxlint.config.mjs",
  "oxc.fixKind": "dangerous_fix_or_suggestion",
  "oxc.typeAware": true,
  "js/ts.experimental.useTsgo": true,
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.native-preview.tsdk": "node_modules/@typescript/native-preview",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always",
    "source.fixAllDangerous.oxc": "always"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "jest.autoRun": "off",
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "prisma.pinToPrisma6": true
}
