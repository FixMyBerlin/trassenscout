{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Trassenscout: dev server",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run dev"
    },
    {
      "name": "Trassenscout: debug client (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://127.0.0.1:4000"
    },
    {
      "name": "Trassenscout: dev + Chrome",
      "type": "node-terminal",
      "request": "launch",
      "command": "bun run dev",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://[^\\s]+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    }
  ]
}
