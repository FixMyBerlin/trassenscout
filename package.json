{
  "name": "trassenscout",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0",
  "author": "FixMyCity <hello@fixmycity.de>",
  "scripts": {
    "start": "bun .output/server/index.mjs",
    "dev": "vite dev --host 127.0.0.1 --port 4000",
    "predev": "bun run --sequential predev:*",
    "predev:1docker": "bun scripts/predev/checkDocker.ts",
    "predev:2migration": "bun scripts/predev/checkMigration.ts",
    "predev:3updates": "bun scripts/predev/checkPackageUpdates.ts",
    "generate-favicons": "bun scripts/generate-favicons/process.ts",
    "postdev": "bun scripts/ask-stop-docker.ts",
    "build": "vite build",
    "preview": "NITRO_HOST=127.0.0.1 NITRO_PORT=4000 bun .output/server/index.mjs",
    "bleach": "rm -rf node_modules/ .output/ && bun install",
    "bleach-full": "rm -f bun.lock && bun run bleach",
    "studio": "bun prisma studio",
    "mail-preview": "VITE_APP_ORIGIN=http://localhost:4000 email dev",
    "open-types": "code \"node_modules/.prisma/client/index.d.ts\"",
    "migrate": "bun prisma migrate dev",
    "migrate-create": "bun run --sequential migrate-create:*",
    "migrate-create:1write": "bun prisma migrate dev --create-only",
    "migrate-create:2format": "oxfmt --config oxfmt.config.mjs --write ./prisma/migrations",
    "migrate-create:3open": "code $(rg --files ./prisma/migrations -g 'migration.sql' | xargs ls -t | sed -n '1p')",
    "migrate-check": "bun prisma migrate status",
    "migrate-check-test": "bun --env-file=.env.test prisma migrate status",
    "migrate-compare": "git diff origin/main... -- prisma/migrations",
    "auth-migrate-accounts": "bun scripts/auth/migrateBetterAuthAccounts.ts",
    "auth-migrate-accounts-write": "bun scripts/auth/migrateBetterAuthAccounts.ts --write",
    "db-get-dump": "bun scripts/db-pull/get-dump.ts",
    "db-get-dump-staging": "bun scripts/db-pull/get-dump.ts -s",
    "db-restore-local": "bun run predev && bun scripts/db-pull/restore-local.ts",
    "db-restore-staging": "bun scripts/db-pull/restore-staging.ts",
    "alkis-audit": "bun scripts/alkis-wfs/audit.ts",
    "alkis-update-config": "bun scripts/alkis-wfs/update-config.ts",
    "check": "bun run --parallel migrate-check-test type-check lint-check format-check test",
    "check-full": "bun run --sequential check e2e",
    "type-check": "tsc --noEmit",
    "lint": "oxlint --fix --fix-dangerously --deny-warnings -c oxlint.config.mjs",
    "lint-check": "oxlint --deny-warnings -c oxlint.config.mjs",
    "format": "oxfmt --config oxfmt.config.mjs --write .",
    "format-check": "oxfmt --config oxfmt.config.mjs --check .",
    "test": "bun scripts/test/withTestDb.ts vitest run --passWithNoTests",
    "test-watch": "bun scripts/test/withTestDb.ts vitest watch",
    "e2e": "playwright test --project=chromium",
    "e2e-smoke": "playwright test --project=chromium tests/smoke tests/dashboard tests/public",
    "e2e-project": "playwright test --project=chromium tests/project",
    "e2e-admin": "playwright test --project=chromium tests/admin",
    "seed": "bun run predev && bun run migrate && bun prisma migrate reset && bun prisma db seed",
    "update": "bun scripts/updatePackages/index.ts",
    "knip": "knip --config knip.config.mjs",
    "env-check:verify-manifest": "bun .github/scripts/verify-env-manifest.ts",
    "env-check:docs": "bun run --sequential env-check:docs:*",
    "env-check:docs:1sync": "bun .github/scripts/generate-github-readme.ts",
    "env-check:docs:2format": "bun run format",
    "env-check": "bun run --parallel env-check:*",
    "release": "gh pr create --base main --head develop --title \"Release $(date '+%Y-%m-%d')\" --body \"\"",
    "prepare": "husky",
    "postinstall": "bun scripts/prisma-generate-placeholder/index.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3",
    "@aws-sdk/client-s3": "3.1057.0",
